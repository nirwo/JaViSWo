{
  "name": "claude-cockpit",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": { "node": ">=22" },
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "npm --workspace @cockpit/server run dev",
    "build": "npm --workspaces run build",
    "test": "npm --workspaces run test --if-present",
    "lint": "eslint packages",
    "format": "prettier --write packages"
  },
  "devDependencies": {
    "@types/node": "22.7.4",
    "eslint": "9.39.4",
    "prettier": "3.8.3",
    "tsx": "4.22.0",
    "typescript": "5.6.2",
    "typescript-eslint": "8.59.3",
    "vitest": "3.2.4"
  }
}
