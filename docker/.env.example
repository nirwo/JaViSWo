# JaViSWo Docker — copy to .env and edit
#
# HOST_IP — the LAN IP of the Mac running the cockpit. dnsmasq points
# javiswo.local at this IP. Find yours with:
#     ipconfig getifaddr en0       # Wi-Fi, usually
#     ipconfig getifaddr en1       # Ethernet
HOST_IP=10.100.102.26

# ROUTER_IP — your LAN gateway. dnsmasq forwards LOCAL-domain queries
# here (so router-local records like nas.lan keep working) but does
# NOT use it for general internet queries (those go to the filtered
# upstreams below). Find yours with:
#     netstat -nr | grep default | awk 'NR==1 {print $2}'
ROUTER_IP=10.100.102.1

# ── Upstream DNS profile ──────────────────────────────────────────────
# Pick one. The setup-network.sh script asks you which to use.
#
#   family   — Cloudflare Family (1.1.1.3) + AdGuard Family
#              (94.140.14.15). Blocks malware, phishing, AND adult
#              content. Best for shared households with kids. This is
#              the default.
#   clean    — Cloudflare Malware (1.1.1.2) + AdGuard Default
#              (94.140.14.14). Blocks malware + trackers + ads but
#              NOT adult content.
#   adblock  — AdGuard Default (94.140.14.14) first for aggressive ad
#              blocking, Cloudflare 1.1.1.1 as fallback. No content
#              filtering beyond ads/trackers.
#   vanilla  — Cloudflare 1.1.1.1 + Google 8.8.8.8. No filtering, raw
#              public DNS. Fastest, no protection.
UPSTREAM_PROFILE=family

# The actual upstream IPs derived from UPSTREAM_PROFILE. These are
# auto-set by setup-network.sh / docker/up.sh based on the profile —
# you can override here if you want a custom combo.
UPSTREAM_DNS_1=1.1.1.3
UPSTREAM_DNS_2=94.140.14.15

# Optional — admin password for the dnsmasq web UI on http://127.0.0.1:5380
DNS_ADMIN_PASS=changeme