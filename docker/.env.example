# JaViSWo Docker — copy to .env and edit
#
# HOST_IP — the LAN IP of the Mac running the cockpit. dnsmasq points
# javiswo.local at this IP. Find yours with:
#     ipconfig getifaddr en0       # Wi-Fi, usually
#     ipconfig getifaddr en1       # Ethernet
HOST_IP=10.100.102.26

# ROUTER_IP — your LAN gateway. dnsmasq forwards unknown queries here
# FIRST (then public DNS as fallback) so router-local DNS records
# (nas.lan, printer.lan, smart-home device names) keep working.
# Find yours with:
#     netstat -nr | grep default | awk 'NR==1 {print $2}'
ROUTER_IP=10.100.102.1

# Optional — admin password for the dnsmasq web UI on http://127.0.0.1:5380
DNS_ADMIN_PASS=changeme

# scripts/setup-network.sh populates HOST_IP and ROUTER_IP automatically.
