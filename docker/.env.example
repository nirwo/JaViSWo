# JaViSWo Docker — copy to .env and edit
#
# HOST_IP — the LAN IP of the Mac running the cockpit. Pi-hole points
# javiswo.local at this IP via /etc/pihole/custom.list. Find yours with:
#     ipconfig getifaddr en0       # Wi-Fi, usually
#     ipconfig getifaddr en1       # Ethernet
HOST_IP=10.100.102.26

# ROUTER_IP — your LAN gateway. Used for reference / setup-network.sh
# instructions. Pi-hole forwards LAN-scoped queries here automatically.
#     netstat -nr | grep default | awk 'NR==1 {print $2}'
ROUTER_IP=10.100.102.1

# TZ — timezone for Pi-hole's logs and stats.
TZ=Asia/Jerusalem

# PIHOLE_PASSWORD — admin password for the web UI at
# http://localhost:8053/admin/ . CHANGE THIS before exposing.
PIHOLE_PASSWORD=changeme

# ── Upstream DNS profile ──────────────────────────────────────────────
# Pi-hole forwards general internet queries to these resolvers. Each
# profile uses a single provider on both primary and secondary so
# load-balancing always returns consistent block decisions.
#
#   family   — Cloudflare Family (1.1.1.3) + Cloudflare Family v2
#              (1.0.0.3). Blocks malware, phishing, AND adult content.
#              Recommended for households with kids. This is the
#              default.
#   clean    — Cloudflare Malware (1.1.1.2) + Cloudflare Malware v2
#              (1.0.0.2). Blocks malware (no adult filter).
#   adblock  — AdGuard Default (94.140.14.14) + AdGuard Default v2
#              (94.140.15.15). Aggressive ad/tracker blocking.
#              Family-safe filtering off — supplement with Pi-hole's
#              own adlists if you want it.
#   vanilla  — Cloudflare 1.1.1.1 + Cloudflare 1.0.0.1. No filtering
#              from upstream; Pi-hole's own blocklists still apply.
UPSTREAM_PROFILE=family

# Auto-set by up.sh based on UPSTREAM_PROFILE; override if you want a
# custom pair.
UPSTREAM_DNS_1=1.1.1.3
UPSTREAM_DNS_2=1.0.0.3
